---
const steps = [
  {
    step: '01',
    title: 'Te inscribes',
    description: 'Realizas tu pago y en minutos recibes acceso al programa completo en tu correo.',
    detail: 'Acceso inmediato',
  },
  {
    step: '02',
    title: 'Te mides',
    description: 'Sigues la guía de medición inicial: fotos de progreso y medidas con cinta métrica desde casa.',
    detail: 'Día 1',
  },
  {
    step: '03',
    title: 'Sigues el plan',
    description: 'Semana a semana tienes tus menús, rutinas y lista de compras. Solo sigue el programa.',
    detail: 'Semanas 1 — 4',
  },
  {
    step: '04',
    title: 'Ves resultados',
    description: 'Check-in a las 2 semanas. Al terminar las 4 semanas comparas y ves tu transformación.',
    detail: 'Día 28',
  },
];
---

<section class="py-24 bg-olive-dark overflow-hidden">
  <div class="max-w-5xl mx-auto px-6">

    <div class="text-center mb-20">
      <p class="font-sans text-xs font-bold tracking-widest uppercase text-sand mb-4">Cómo funciona</p>
      <h2 class="font-serif text-4xl md:text-5xl font-medium text-cream leading-tight">
        Tan simple como<br/>
        <em class="font-normal text-sand">seguir el proceso</em>
      </h2>
    </div>

    <!-- Timeline horizontal -->
    <div class="relative">

      <!-- Línea conectora -->
      <div class="hidden md:block absolute top-[28px] left-[calc(12.5%)] right-[calc(12.5%)] h-px bg-sand/20"></div>

      <!-- Steps -->
      <div class="grid md:grid-cols-4 gap-8">
        {steps.map((s, i) => (
          <div class="flex flex-col items-center text-center md:items-start md:text-left">

            <!-- Número con círculo -->
            <div class="relative mb-8 flex flex-col items-center md:items-start">
              <div class="relative z-10 w-14 h-14 rounded-full border border-sand/40 bg-olive-dark flex items-center justify-center mb-4">
                <span class="font-serif text-base font-medium text-sand">{s.step}</span>
              </div>
              <!-- Etiqueta de tiempo -->
              <span class="font-sans text-[10px] font-bold tracking-widest uppercase text-sand/50">{s.detail}</span>
            </div>

            <!-- Contenido -->
            <div class="flex-1">
              <!-- Línea decorativa lateral -->
              <div class="hidden md:block w-8 h-px bg-sand/40 mb-4"></div>
              <h3 class="font-serif text-xl font-medium text-cream mb-3 leading-tight">{s.title}</h3>
              <p class="font-sans font-light text-sm text-olive-sage leading-relaxed">{s.description}</p>
            </div>

          </div>
        ))}
      </div>

      <!-- Barra de progreso decorativa en mobile -->
      <div class="md:hidden mt-12 flex items-center justify-center gap-2">
        {steps.map((_, i) => (
          <div class={`h-px bg-sand/40 ${i === 0 ? 'w-2' : 'w-8'}`}></div>
        ))}
      </div>

    </div>

    <!-- CTA dentro de la sección -->
    <div class="mt-20 pt-12 border-t border-sand/20 flex flex-col md:flex-row items-center justify-between gap-6">
      <div>
        <p class="font-serif text-2xl font-medium text-cream mb-1">¿Listo para empezar?</p>
        <p class="font-sans font-light text-sm text-olive-sage">4 semanas. Nutrición + ejercicio. Resultados reales.</p>
      </div>
      <a href="#pricing" class="btn-primary shrink-0">
        Ver precio y contenido
      </a>
    </div>

  </div>
</section>
