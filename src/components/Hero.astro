---
---

<section class="min-h-screen bg-cream flex items-center pt-24 pb-16">
  <div class="max-w-5xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center">

    <!-- Texto -->
    <div>
      <p class="section-label mb-6">Nutrición Deportiva · 4 Semanas</p>

      <h1 class="font-serif text-5xl md:text-6xl font-medium text-olive-dark leading-[1.05] mb-2">
        Tu rendimiento
      </h1>
      <h1 class="font-serif text-5xl md:text-6xl font-normal italic text-sand leading-[1.05] mb-6">
        comienza en tu plato
      </h1>

      <p class="font-sans font-light text-olive-mid leading-relaxed mb-8 max-w-sm">
        Un programa de nutrición y entrenamiento diseñado para quienes entrenan crossfit, hyrox y funcional. Sin dietas imposibles, con ingredientes reales.
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a href="#pricing" class="btn-primary text-center">
          Comenzar ahora — $499 MXN
        </a>
        <a href="#program" class="btn-secondary text-center">
          Ver programa
        </a>
      </div>

      <!-- Trust signals -->
      <div class="flex items-center gap-6 mt-10 pt-8 border-t border-sand-light">
        <div>
          <p class="font-serif text-2xl font-medium text-olive-dark">4</p>
          <p class="font-sans text-xs text-olive-mid tracking-wide">Semanas</p>
        </div>
        <div class="w-px h-8 bg-sand-light"></div>
        <div>
          <p class="font-serif text-2xl font-medium text-olive-dark">100%</p>
          <p class="font-sans text-xs text-olive-mid tracking-wide">Digital</p>
        </div>
        <div class="w-px h-8 bg-sand-light"></div>
        <div>
          <p class="font-serif text-2xl font-medium text-olive-dark">+Ejercicio</p>
          <p class="font-sans text-xs text-olive-mid tracking-wide">Incluido</p>
        </div>
      </div>
    </div>

    <!-- Imagen -->
    <div class="relative hidden md:block">
      <div class="aspect-[3/4] overflow-hidden">
        <img
          src="/move-eat-program/alexa-hero.png"
          alt="Alexa Mendivil, nutrióloga deportiva"
          class="w-full h-full object-cover object-top"
        />
      </div>
      <!-- Badge flotante -->
      <div class="absolute -bottom-4 -left-4 bg-olive-dark text-cream px-5 py-4">
        <p class="font-sans text-[10px] font-bold tracking-widest uppercase text-sand mb-1">Nutrióloga certificada</p>
        <p class="font-serif text-lg font-medium">Alexa Mendivil</p>
      </div>
    </div>

  </div>
</section>
